# Pyxis MCP Server Configuration
# Copy to .env and modify as needed

# ── Mode ──────────────────────────────────────────────────────────────────────
# "simulator" — fully in-memory, no network (default)
# "mock"      — pyxis-client.ts returns realistic Pyxis-shaped responses (no network)
# "live"      — pyxis-client.ts makes real HTTP calls to PYXIS_BASE_URL
PYXIS_MODE=mock

# ── Live / Mock sandbox credentials (required when PYXIS_MODE=live) ───────────
# PYXIS_BASE_URL=https://sandbox.csipay.com:8080
# PYXIS_USERNAME=your_username
# PYXIS_PASSWORD=your_password
# PYXIS_SHARED_SECRET=your_64_char_pyxisAccess_secret
# PYXIS_TERMINAL_ID=your_terminal_uuid

# ── Optional: lock down simulator credentials ─────────────────────────────────
# PYXIS_MCP_USERNAME=your_username
# PYXIS_MCP_PASSWORD=your_password

# ── Audit log file path (default: pyxis-audit.log) ───────────────────────────
# PYXIS_AUDIT_LOG=pyxis-audit.log

# ── Fee rate (0.0 to 1.0, default: 0.03 = 3%) ────────────────────────────────
# PYXIS_FEE_RATE=0.03
